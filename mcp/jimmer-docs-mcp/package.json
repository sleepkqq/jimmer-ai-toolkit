{
  "name": "jimmer-docs-mcp",
  "version": "1.0.0",
  "description": "MCP server for searching Jimmer ORM documentation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/bundle.js --minify",
    "start": "node dist/bundle.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
